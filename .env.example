# Copy this file to .env and fill in the actual values.
# .env is git-ignored and should never be committed.

# NTC-Templates: path to the ntc-templates templates directory
# Default assumes ntc-templates was cloned alongside this repo (see README installation steps).
# Override with an absolute path if you cloned it elsewhere.
NET_TEXTFSM=./ntc-templates/ntc_templates/templates

# Flask-Security
NETEYE_SECRET_KEY=change-me-to-a-random-secret
NETEYE_SECURITY_PASSWORD_SALT=change-me-to-a-random-salt

# Node credential encryption: encrypts SSH username/password/enable at rest in the
# database. Kept separate from NETEYE_SECRET_KEY — rotating SECRET_KEY (session/CSRF
# signing) must never break decryption of already-stored device credentials.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NETEYE_NODE_CREDENTIAL_KEY=change-me-to-a-random-key

# Administrator
NETEYE_ADMIN_PASSWORD=change-me

# Device credentials used by discover_network to auto-connect to discovered neighbors (add/remove entries as needed)
NETEYE_DISCOVERY_CREDENTIALS__1__USERNAME=admin
NETEYE_DISCOVERY_CREDENTIALS__1__PASSWORD=cisco
NETEYE_DISCOVERY_CREDENTIALS__1__ENABLE=cisco
NETEYE_DISCOVERY_CREDENTIALS__2__USERNAME=admin
NETEYE_DISCOVERY_CREDENTIALS__2__PASSWORD=juniper
NETEYE_DISCOVERY_CREDENTIALS__2__ENABLE=juniper
NETEYE_DISCOVERY_CREDENTIALS__3__USERNAME=admin
NETEYE_DISCOVERY_CREDENTIALS__3__PASSWORD=cisco
NETEYE_DISCOVERY_CREDENTIALS__3__ENABLE=cisco
