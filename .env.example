# Copy this file to .env and fill in the actual values.
# .env is git-ignored and should never be committed.

# Flask-Security
DYNACONF_SECRET_KEY=change-me-to-a-random-secret
DYNACONF_SECURITY_PASSWORD_SALT=change-me-to-a-random-salt

# Administrator
DYNACONF_ADMIN_PASSWORD=change-me

# Device credentials for auto-connect (add/remove entries as needed)
DYNACONF_CREDENTIALS__1__USERNAME=admin
DYNACONF_CREDENTIALS__1__PASSWORD=cisco
DYNACONF_CREDENTIALS__1__ENABLE=cisco
DYNACONF_CREDENTIALS__2__USERNAME=admin
DYNACONF_CREDENTIALS__2__PASSWORD=juniper
DYNACONF_CREDENTIALS__2__ENABLE=juniper
DYNACONF_CREDENTIALS__3__USERNAME=admin
DYNACONF_CREDENTIALS__3__PASSWORD=cisco
DYNACONF_CREDENTIALS__3__ENABLE=cisco
