# Copy this file to .env and fill in the actual values.
# .env is git-ignored and should never be committed.

# Flask-Security
NETEYE_SECRET_KEY=change-me-to-a-random-secret
NETEYE_SECURITY_PASSWORD_SALT=change-me-to-a-random-salt

# Administrator
NETEYE_ADMIN_PASSWORD=change-me

# Device credentials for auto-connect (add/remove entries as needed)
NETEYE_CREDENTIALS__1__USERNAME=admin
NETEYE_CREDENTIALS__1__PASSWORD=cisco
NETEYE_CREDENTIALS__1__ENABLE=cisco
NETEYE_CREDENTIALS__2__USERNAME=admin
NETEYE_CREDENTIALS__2__PASSWORD=juniper
NETEYE_CREDENTIALS__2__ENABLE=juniper
NETEYE_CREDENTIALS__3__USERNAME=admin
NETEYE_CREDENTIALS__3__PASSWORD=cisco
NETEYE_CREDENTIALS__3__ENABLE=cisco
